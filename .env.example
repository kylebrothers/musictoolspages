# ── Infrastructure ─────────────────────────────────────────────────────────
NAS_IP=192.168.0.134
NAS_MOUNT_PATH=/mnt/nas
HOST_PORT=5001
APP_NAME=playlistrec

# ── Flask ───────────────────────────────────────────────────────────────────
SECRET_KEY=
FLASK_ENV=production
FLASK_DEBUG=false

# ── Claude ──────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
# Optional: pin to a specific model. If unset, latest Sonnet is auto-detected.
CLAUDE_MODEL=

# ── Last.fm ─────────────────────────────────────────────────────────────────
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Spotify ─────────────────────────────────────────────────────────────────
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://192.168.0.<server>:5001/spotify/callback

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=/app/database/playlistrec.db

# ── NAS directories to create before first run ─────────────────────────────
# NAS:/Docker/playlistrec/config
# NAS:/Docker/playlistrec/logs
# NAS:/Docker/playlistrec/server_files
# NAS:/Docker/playlistrec/database
