# ── Infrastructure ─────────────────────────────────────────────────────────
NAS_IP=192.168.0.134
NAS_MOUNT_PATH=/mnt/nas
HOST_PORT=5000                  # assign an open port on your server
APP_NAME=playlistrec

# ── Flask ───────────────────────────────────────────────────────────────────
SECRET_KEY=                     # auto-generated by make setup
FLASK_ENV=production
FLASK_DEBUG=false

# ── API Keys ────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
LASTFM_API_KEY=                 # https://www.last.fm/api/account/create

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=/app/database/playlistrec.db   # set by docker-compose; override only if needed

# ── NAS directories to create before first run ─────────────────────────────
# NAS:/Docker/playlistrec/logs
# NAS:/Docker/playlistrec/server_files
# NAS:/Docker/playlistrec/database
